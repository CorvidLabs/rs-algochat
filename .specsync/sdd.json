{
  "version": 1,
  "enabled": true,
  "require_change_for_meaningful_files": true,
  "meaningful_paths": [
    "src/",
    "tests/",
    "site/",
    ".github/",
    "Cargo.toml",
    "Cargo.lock",
    "fledge.toml",
    ".trust.toml",
    ".augur.toml",
    ".attest.json",
    "specs/",
    "action.yml",
    "package.json",
    "bun.lock",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "Package.swift",
    "Package.resolved",
    "go.mod",
    "go.sum",
    "pyproject.toml",
    "uv.lock",
    "requirements.txt",
    ".specsync/sdd.json",
    ".specsync/config.toml",
    ".specsync/config.json",
    ".specsync/version"
  ],
  "ignored_paths": [],
  "verification_commands": [
    "cargo fmt --all -- --check",
    "cargo clippy -- -D warnings",
    "cargo test --verbose",
    "cargo test --test cross_impl --verbose"
  ],
  "custom_artifacts": {},
  "principles_file": null
}
